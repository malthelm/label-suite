---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { royalties_revenue, artists, releases } from "../../db/schema";
import { eq, desc, sql } from "drizzle-orm";

const royaltyRows = await db.select({
  id: royalties_revenue.id,
  record_name: royalties_revenue.record_name,
  statement_period: royalties_revenue.statement_period,
  source: royalties_revenue.source,
  gross_revenue: royalties_revenue.gross_revenue,
  costs: royalties_revenue.costs,
  net_revenue: royalties_revenue.net_revenue,
  paid_out: royalties_revenue.paid_out,
  payment_date: royalties_revenue.payment_date,
  notes: royalties_revenue.notes,
  revenue_type: royalties_revenue.revenue_type,
  artist_id: royalties_revenue.artist_id,
  release_id: royalties_revenue.release_id,
  artist_name: artists.name,
  release_title: releases.title,
}).from(royalties_revenue)
  .leftJoin(artists, eq(royalties_revenue.artist_id, artists.id))
  .leftJoin(releases, eq(royalties_revenue.release_id, releases.id))
  .orderBy(desc(royalties_revenue.created_at));

// Group by artist name
const artistMap = new Map<string, typeof royaltyRows>();
for (const row of royaltyRows) {
  const key = row.artist_name || "Unassigned";
  if (!artistMap.has(key)) artistMap.set(key, []);
  artistMap.get(key)!.push(row);
}

// Sort groups by artist name
const grouped = [...artistMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));

// Totals
const totals = await db.select({
  total_net: sql<number>`coalesce(sum(${royalties_revenue.net_revenue}), 0)`,
  unpaid_count: sql<number>`coalesce(sum(case when ${royalties_revenue.paid_out} = 'unpaid' then 1 else 0 end), 0)`,
}).from(royalties_revenue);

const totalNet = totals[0]?.total_net ?? 0;
const unpaidCount = totals[0]?.unpaid_count ?? 0;
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Royalties &amp; Revenue</h1>
    </div>

    <!-- Summary cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-card border border-border rounded-xl p-5">
        <p class="text-sm text-muted-foreground">Total Net Revenue</p>
        <p class="text-3xl font-bold mt-1">${Number(totalNet).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</p>
      </div>
      <div class="bg-card border border-border rounded-xl p-5">
        <p class="text-sm text-muted-foreground">Unpaid Statements</p>
        <p class="text-3xl font-bold mt-1">{unpaidCount}</p>
      </div>
    </div>

    {!royaltyRows.length ? (
      <div class="p-12 text-center text-muted-foreground border-2 border-dashed border-border rounded-xl">
        <p class="text-lg">No royalty records yet.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {grouped.map(([artist, rows]) => (
          <section>
            <h2 class="text-xl font-semibold mb-3">{artist}</h2>
            <div class="bg-card border border-border rounded-xl overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-border bg-muted/50">
                    <th class="text-left px-4 py-3 font-medium">Record</th>
                    <th class="text-left px-4 py-3 font-medium">Period</th>
                    <th class="text-left px-4 py-3 font-medium">Source</th>
                    <th class="text-right px-4 py-3 font-medium">Gross</th>
                    <th class="text-right px-4 py-3 font-medium">Costs</th>
                    <th class="text-right px-4 py-3 font-medium">Net</th>
                    <th class="text-center px-4 py-3 font-medium">Status</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border">
                  {rows.map((r) => (
                    <tr class="hover:bg-accent/50 transition-colors">
                      <td class="px-4 py-3">
                        <p class="font-medium">{r.record_name}</p>
                        {r.release_title && <p class="text-xs text-muted-foreground">{r.release_title}</p>}
                      </td>
                      <td class="px-4 py-3 text-muted-foreground">{r.statement_period || "—"}</td>
                      <td class="px-4 py-3">{r.source || "—"}</td>
                      <td class="px-4 py-3 text-right">{r.gross_revenue != null ? `$${Number(r.gross_revenue).toLocaleString("en-US", { minimumFractionDigits: 2 })}` : "—"}</td>
                      <td class="px-4 py-3 text-right">{r.costs != null ? `$${Number(r.costs).toLocaleString("en-US", { minimumFractionDigits: 2 })}` : "—"}</td>
                      <td class="px-4 py-3 text-right font-medium">{r.net_revenue != null ? `$${Number(r.net_revenue).toLocaleString("en-US", { minimumFractionDigits: 2 })}` : "—"}</td>
                      <td class="px-4 py-3 text-center">
                        <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${
                          r.paid_out === "paid" ? "bg-green-100 text-green-700" :
                          r.paid_out === "pending" ? "bg-yellow-100 text-yellow-700" :
                          "bg-red-100 text-red-700"
                        }`}>
                          {r.paid_out || "unpaid"}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</AppLayout>