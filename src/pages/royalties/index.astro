---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { royalties_revenue, artists, releases } from "../../db/schema";
import { eq, desc, asc, sql } from "drizzle-orm";
import { RoyaltyManager } from "../../components/royalties/RoyaltyManager";
import type { RoyaltyRecord } from "../../components/royalties/RoyaltyForm";

const royaltyRows = await db.select({
  id: royalties_revenue.id,
  record_name: royalties_revenue.record_name,
  statement_period: royalties_revenue.statement_period,
  source: royalties_revenue.source,
  artist_id: royalties_revenue.artist_id,
  release_id: royalties_revenue.release_id,
  gross_revenue: royalties_revenue.gross_revenue,
  costs: royalties_revenue.costs,
  net_revenue: royalties_revenue.net_revenue,
  paid_out: royalties_revenue.paid_out,
  payment_date: royalties_revenue.payment_date,
  notes: royalties_revenue.notes,
  revenue_type: royalties_revenue.revenue_type,
  artist_name: artists.name,
  release_title: releases.title,
}).from(royalties_revenue)
  .leftJoin(artists, eq(royalties_revenue.artist_id, artists.id))
  .leftJoin(releases, eq(royalties_revenue.release_id, releases.id))
  .orderBy(desc(royalties_revenue.created_at));

// KPIs
const totals = await db.select({
  total_net: sql<number>`coalesce(sum(${royalties_revenue.net_revenue}), 0)`,
  unpaid_count: sql<number>`coalesce(sum(case when ${royalties_revenue.paid_out} = 'unpaid' then 1 else 0 end), 0)`,
  paid_this_year: sql<number>`coalesce(sum(case when ${royalties_revenue.paid_out} = 'paid' and ${royalties_revenue.payment_date} >= ${new Date().getFullYear() + '-01-01'} then 1 else 0 end), 0)`,
}).from(royalties_revenue);

const totalNet = totals[0]?.total_net ?? 0;
const unpaidCount = totals[0]?.unpaid_count ?? 0;
const paidThisYear = totals[0]?.paid_this_year ?? 0;

const artistRows = await db.select({ id: artists.id, name: artists.name }).from(artists).orderBy(asc(artists.name));
const releaseRows = await db.select({ id: releases.id, title: releases.title }).from(releases).orderBy(asc(releases.title));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Royalties &amp; Revenue</h1>
      <p class="text-muted-foreground mt-1">Streaming revenue, mechanicals, sync licensing, and physical sales.</p>
    </div>
    <RoyaltyManager client:load
      initialRoyalties={royaltyRows as Array<RoyaltyRecord & { artist_name?: string | null; release_title?: string | null }>}
      artists={artistRows}
      releases={releaseRows}
      totalNet={totalNet}
      unpaidCount={unpaidCount}
      paidThisYear={paidThisYear}
    />
  </div>
</AppLayout>