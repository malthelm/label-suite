---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { documents, artists, releases, contacts } from "../../db/schema";
import { desc, eq, asc } from "drizzle-orm";
import { DocumentManager } from "../../components/documents/DocumentManager";
import type { Document } from "../../components/documents/DocumentForm";

const docRows = await db.select({
  id: documents.id, name: documents.name, doc_type: documents.doc_type,
  release_id: documents.release_id, artist_id: documents.artist_id, contact_id: documents.contact_id,
  status: documents.status, file_link: documents.file_link, notes: documents.notes,
  artist_name: artists.name, release_title: releases.title, contact_name: contacts.name,
}).from(documents).leftJoin(artists, eq(documents.artist_id, artists.id))
  .leftJoin(releases, eq(documents.release_id, releases.id))
  .leftJoin(contacts, eq(documents.contact_id, contacts.id))
  .orderBy(desc(documents.created_at)).limit(50);

const artistRows = await db.select({ id: artists.id, name: artists.name }).from(artists).orderBy(asc(artists.name));
const releaseRows = await db.select({ id: releases.id, title: releases.title }).from(releases).orderBy(asc(releases.title));
const contactRows = await db.select({ id: contacts.id, name: contacts.name }).from(contacts).orderBy(asc(contacts.name));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Documents</h1>
      <p class="text-muted-foreground mt-1">Contracts, licenses, split sheets, and legal docs.</p>
    </div>
    <DocumentManager client:load
      initialDocuments={docRows as Array<Document & { artist_name?: string | null; release_title?: string | null; contact_name?: string | null }>}
      artists={artistRows}
      releases={releaseRows}
      contacts={contactRows}
    />
  </div>
</AppLayout>