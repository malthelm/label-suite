---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { contacts } from "../../db/schema";
import { asc } from "drizzle-orm";
import { ContactCreateDialog } from "../../components/contacts/ContactCreateDialog";
import { ContactEditButton, ContactDeleteButton } from "../../components/contacts/ContactActionButtons";

const contactRows = await db.select().from(contacts).orderBy(asc(contacts.name));
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Contacts</h1>
      <ContactCreateDialog client:load />
    </div>

    {!contactRows.length ? (
      <div class="p-12 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-xl">
        <p class="text-lg">No contacts yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {contactRows.map((c) => (
          <div class="block p-5 rounded-xl border border-neutral-200 hover:border-neutral-400 hover:shadow-sm transition-all">
            <h2 class="text-lg font-semibold">{c.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2 text-xs">
              {c.role && <span class="px-2 py-1 bg-neutral-100 rounded-md">{c.role}</span>}
              {c.email && <span class="px-2 py-1 bg-blue-50 text-blue-700 rounded-md">{c.email}</span>}
              {c.company && <span class="px-2 py-1 bg-purple-50 text-purple-700 rounded-md">{c.company}</span>}
            </div>
            {c.phone && <p class="mt-2 text-sm text-neutral-500">{c.phone}</p>}
            {c.notes && <p class="mt-1 text-sm text-neutral-400 line-clamp-2">{c.notes}</p>}
            <div class="mt-3 pt-3 border-t border-neutral-100 flex gap-2">
              <ContactEditButton client:load contact={c} />
              <ContactDeleteButton client:load contact={c} />
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>
