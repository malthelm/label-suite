---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { radio_stations } from "../../db/schema";
import { asc } from "drizzle-orm";
import { RadioStationManager } from "../../components/radio-stations/RadioStationManager";
import type { RadioStation } from "../../components/radio-stations/RadioStationForm";

const stationRows = await db.select().from(radio_stations).orderBy(asc(radio_stations.name));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Radio Stations</h1>
      <p class="text-muted-foreground mt-1">Radio promo CRM — stations, DJs, and contact info.</p>
    </div>
    <RadioStationManager client:load
      initialStations={stationRows as Array<RadioStation>}
    />
  </div>
</AppLayout>