---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { campaigns, releases, artists } from "../../db/schema";
import { desc, eq } from "drizzle-orm";

const campaignRows = await db.select({
  id: campaigns.id, campaign_name: campaigns.campaign_name, campaign_type: campaigns.campaign_type,
  status: campaigns.status, start_date: campaigns.start_date, end_date: campaigns.end_date,
  owner: campaigns.owner, budget_planned: campaigns.budget_planned,
  performance_rating: campaigns.performance_rating, main_platform: campaigns.main_platform,
  release_title: releases.title, artist_name: artists.name,
}).from(campaigns)
  .leftJoin(releases, eq(campaigns.linked_release_id, releases.id))
  .leftJoin(artists, eq(campaigns.linked_artist_id, artists.id))
  .orderBy(desc(campaigns.created_at));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Campaigns</h1>
      <p class="text-muted-foreground mt-1">Marketing campaigns linked to releases and artists.</p>
    </div>

    {!campaignRows.length ? (
      <div class="p-12 text-center text-muted-foreground border-2 border-dashed border-border rounded-xl">
        <p class="text-lg">No campaigns yet.</p>
      </div>
    ) : (
      <div class="bg-card border border-border rounded-xl divide-y divide-border">
        {campaignRows.map((c) => (
          <div class="flex items-center justify-between p-4">
            <div>
              <p class="font-medium">{c.campaign_name}</p>
              <p class="text-sm text-muted-foreground">
                {c.campaign_type || "—"} · {c.artist_name || "—"} · {c.release_title || "—"} · {c.start_date || ""} → {c.end_date || ""}
              </p>
              {c.owner && <p class="text-xs text-muted-foreground">Owner: {c.owner}</p>}
            </div>
            <div class="flex items-center gap-2">
              {c.budget_planned && <span class="text-xs px-2 py-1 rounded bg-muted">{c.budget_planned.toLocaleString()} DKK</span>}
              <span class={`text-xs px-2 py-1 rounded ${c.status === "active" ? "bg-green-100 text-green-700" : c.status === "planning" ? "bg-blue-100 text-blue-700" : "bg-muted text-muted-foreground"}`}>{c.status}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>