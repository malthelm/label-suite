---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { campaigns, releases, artists } from "../../db/schema";
import { desc, eq, asc } from "drizzle-orm";
import { CampaignManager } from "../../components/campaigns/CampaignManager";
import type { Campaign } from "../../components/campaigns/CampaignForm";

const campaignRows = await db.select({
  id: campaigns.id, campaign_name: campaigns.campaign_name, campaign_type: campaigns.campaign_type,
  linked_release_id: campaigns.linked_release_id, linked_artist_id: campaigns.linked_artist_id,
  status: campaigns.status, start_date: campaigns.start_date, end_date: campaigns.end_date,
  owner: campaigns.owner, goal: campaigns.goal,
  budget_planned: campaigns.budget_planned, budget_actual: campaigns.budget_actual,
  kpi_summary: campaigns.kpi_summary, notes: campaigns.notes,
  performance_rating: campaigns.performance_rating, main_platform: campaigns.main_platform,
  release_title: releases.title, artist_name: artists.name,
}).from(campaigns)
  .leftJoin(releases, eq(campaigns.linked_release_id, releases.id))
  .leftJoin(artists, eq(campaigns.linked_artist_id, artists.id))
  .orderBy(desc(campaigns.created_at));

const artistRows = await db.select({ id: artists.id, name: artists.name }).from(artists).orderBy(asc(artists.name));
const releaseRows = await db.select({ id: releases.id, title: releases.title }).from(releases).orderBy(asc(releases.title));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Campaigns</h1>
      <p class="text-muted-foreground mt-1">Marketing campaigns linked to releases and artists.</p>
    </div>
    <CampaignManager client:load
      initialCampaigns={campaignRows as Array<Campaign & { artist_name?: string | null; release_title?: string | null }>}
      artists={artistRows}
      releases={releaseRows}
    />
  </div>
</AppLayout>