---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { releases, artists, tracks } from "../../db/schema";
import { eq, asc } from "drizzle-orm";

const { id } = Astro.params;
if (!id) return Astro.redirect("/releases");

const releaseRows = await db.select({
  id: releases.id,
  title: releases.title,
  format: releases.format,
  release_date: releases.release_date,
  upc_ean: releases.upc_ean,
  cover_art_url: releases.cover_art_url,
  release_ready: releases.release_ready,
  release_missing: releases.release_missing,
  status: releases.status,
  artist_name: artists.name,
}).from(releases).leftJoin(artists, eq(releases.artist_id, artists.id)).where(eq(releases.id, id));

const release = releaseRows[0];
const trackRows = await db.select().from(tracks).where(eq(tracks.release_id, id)).orderBy(asc(tracks.position));
---

<AppLayout>
  {!release ? <p class="text-neutral-500">Release not found.</p> : (
    <div class="space-y-8">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-3xl font-bold tracking-tight">{release.title}</h1>
          <span class={`text-xs px-2 py-1 rounded-md font-medium ${release.release_ready ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"}`}>
            {release.release_ready ? "Ready" : "Not Ready"}
          </span>
        </div>
        <p class="text-neutral-500 mt-1">{release.artist_name} · {release.format} · {release.release_date || "No date"}</p>
      </div>

      {release.release_missing && (
        <div class="p-4 rounded-lg bg-red-50 border border-red-100">
          <p class="text-sm font-medium text-red-800">Missing: {release.release_missing}</p>
        </div>
      )}

      <section>
        <h2 class="text-lg font-semibold mb-3">Tracks ({trackRows.length})</h2>
        <div class="space-y-1">
          {trackRows.map((t) => (
            <div class="flex items-center justify-between p-3 border border-neutral-200 rounded-lg">
              <div>
                <p class="font-medium text-sm">{t.position}. {t.title} {t.version && t.version !== "Main" ? `(${t.version})` : ""}</p>
                <p class="text-xs text-neutral-500">{t.isrc || "No ISRC"} · {t.audio_url ? "Audio ✓" : "No audio"}</p>
              </div>
              <span class={`text-xs px-2 py-1 rounded-md ${t.track_ready ? "bg-green-100 text-green-700" : "bg-neutral-100 text-neutral-600"}`}>
                {t.track_ready ? "Ready" : `Clearance: ${Math.round((t.clearance_progress ?? 0) * 100)}%`}
              </span>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}
</AppLayout>
