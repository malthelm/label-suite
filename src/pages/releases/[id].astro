---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { releases, artists, tracks, works } from "../../db/schema";
import { eq, asc } from "drizzle-orm";
import { ReleaseEditButton, ReleaseDeleteButton } from "../../components/releases/ReleaseActionButtons";
import { TrackEditButton, TrackDeleteButton } from "../../components/tracks/TrackActionButtons";

const { id } = Astro.params;
if (!id) return Astro.redirect("/releases");

const releaseRows = await db.select({
  id: releases.id,
  title: releases.title,
  format: releases.format,
  release_date: releases.release_date,
  upc_ean: releases.upc_ean,
  cover_art_url: releases.cover_art_url,
  release_ready: releases.release_ready,
  release_missing: releases.release_missing,
  status: releases.status,
  artist_id: releases.artist_id,
  artist_name: artists.name,
}).from(releases).leftJoin(artists, eq(releases.artist_id, artists.id)).where(eq(releases.id, id));

const release = releaseRows[0];
const trackRows = await db.select().from(tracks).where(eq(tracks.release_id, id)).orderBy(asc(tracks.position));
const workRows = await db.select({ id: works.id, title: works.title, isrc: works.isrc }).from(works).orderBy(asc(works.title));
const artistRowsForForm = await db.select({ id: artists.id, name: artists.name }).from(artists).orderBy(asc(artists.name));
---

<AppLayout>
  {!release ? <p class="text-muted-foreground">Release not found.</p> : (
    <div class="space-y-8">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-3xl font-bold tracking-tight">{release.title}</h1>
          <span class={`text-xs px-2 py-1 rounded-md font-medium ${release.release_ready ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"}`}>
            {release.release_ready ? "Ready" : "Not Ready"}
          </span>
        </div>
        <p class="text-muted-foreground mt-1">{release.artist_name || "—"} · {release.format} · {release.release_date || "No date"} {release.status && `· ${release.status}`}</p>
        <div class="mt-3 flex gap-2">
          <ReleaseEditButton client:load release={release} artists={artistRowsForForm} />
          <ReleaseDeleteButton client:load release={release} />
        </div>
      </div>

      {release.release_missing && (
        <div class="p-4 rounded-lg bg-red-50 border border-red-100">
          <p class="text-sm font-medium text-red-800">Missing: {release.release_missing}</p>
        </div>
      )}

      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-semibold">Tracks ({trackRows.length})</h2>
          <a href={`/releases/${id}/tracks`} class="text-xs text-muted-foreground hover:text-foreground">Manage tracks →</a>
        </div>
        <div class="space-y-1">
          {trackRows.map((t) => (
            <div class="flex items-center justify-between p-3 border border-border rounded-lg gap-3">
              <div class="flex-1">
                <p class="font-medium text-sm">{t.position}. {t.title} {t.version && t.version !== "Main" ? `(${t.version})` : ""}</p>
                <p class="text-xs text-muted-foreground">{t.isrc || "No ISRC"} · {t.audio_url ? "Audio ✓" : "No audio"}</p>
              </div>
              <span class={`text-xs px-2 py-1 rounded-md ${t.track_ready ? "bg-green-100 text-green-700" : "bg-muted text-muted-foreground"}`}>
                {t.track_ready ? "Ready" : `Clearance: ${Math.round((t.clearance_progress ?? 0) * 100)}%`}
              </span>
              <TrackEditButton client:load track={t} works={workRows} />
              <TrackDeleteButton client:load track={t} />
            </div>
          ))}
        </div>
      </section>
    </div>
  )}
</AppLayout>