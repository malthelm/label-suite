---
import AppLayout from "../layouts/AppLayout.astro";
import { db } from "../lib/db";
import { calls, bugs, releases, artists, contacts } from "../db/schema";
import { eq, asc, desc, and } from "drizzle-orm";
import { BugInbox } from "../components/BugInbox";

const today = new Date().toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" });

const callRows = await db.select({
  id: calls.id, title: calls.title, start: calls.start, notes: calls.notes,
  contact_name: contacts.name, release_title: releases.title,
}).from(calls).leftJoin(contacts, eq(calls.contact_id, contacts.id)).leftJoin(releases, eq(calls.release_id, releases.id)).orderBy(asc(calls.start)).limit(20);

const bugRows = await db.select().from(bugs).where(eq(bugs.status, "logged")).orderBy(asc(bugs.priority)).limit(10);

const blockedRows = await db.select({
  id: releases.id, title: releases.title, release_date: releases.release_date,
  artist_name: artists.name,
}).from(releases).leftJoin(artists, eq(releases.artist_id, artists.id)).where(eq(releases.release_ready, false)).orderBy(asc(releases.release_date));
---

<AppLayout>
  <div class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Today Hub</h1>
      <p class="text-muted-foreground mt-1">{today}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <section>
        <h2 class="text-lg font-semibold mb-3">📞 Calls ({callRows.length})</h2>
        <div class="space-y-2">
          {!callRows.length && <p class="text-sm text-muted-foreground">No upcoming calls.</p>}
          {callRows.map((c) => (
            <div class="p-4 rounded-lg border border-border">
              <h3 class="font-medium text-sm">{c.title}</h3>
              <p class="text-xs text-muted-foreground mt-1">{c.contact_name}{c.release_title ? ` — ${c.release_title}` : ""}</p>
              {c.start && <p class="text-xs text-muted-foreground mt-1">{new Date(c.start).toLocaleDateString()} · {new Date(c.start).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</p>}
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-lg font-semibold mb-3">⛔ Blocked ({blockedRows.length})</h2>
        <div class="space-y-2">
          {!blockedRows.length && <p class="text-sm text-muted-foreground">All clear! 🎉</p>}
          {blockedRows.map((r) => (
            <a href={`/releases/${r.id}`} class="block p-4 rounded-lg border border-red-100 bg-red-50/50 hover:bg-red-50 transition-colors">
              <h3 class="font-medium text-sm">{r.title}</h3>
              <p class="text-xs text-muted-foreground mt-1">{r.artist_name} · {r.release_date || "No date"}</p>
            </a>
          ))}
        </div>
      </section>

      <section>
        <BugInbox client:load initialBugs={bugRows} />
      </section>
    </div>
  </div>
</AppLayout>