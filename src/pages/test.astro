---
import { supabase } from "../lib/supabase";

let message = "Testing...";
try {
  const { data } = await supabase.from("artists").select("count");
  message = `Connected! Found artists.`;
} catch (e: any) {
  message = `Error: ${e.message}`;
}
---

<!DOCTYPE html>
<html>
<body>
  <h1>{message}</h1>
</body>
</html>
