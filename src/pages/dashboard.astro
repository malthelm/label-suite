---
import AppLayout from "../layouts/AppLayout.astro";
import { db } from "../lib/db";
import { artists, releases, bugs } from "../db/schema";
import { count, eq } from "drizzle-orm";
import { ReleasePipeline } from "../components/dashboard/ReleasePipeline";

const artistCount = await db.select({ value: count() }).from(artists);
const releaseRows = await db.select({
  id: releases.id, title: releases.title, format: releases.format,
  status: releases.status, release_date: releases.release_date,
  release_ready: releases.release_ready, artist_name: artists.name,
}).from(releases).leftJoin(artists, eq(releases.artist_id, artists.id));
const bugCount = await db.select({ value: count() }).from(bugs).where(eq(bugs.status, "logged"));
const readyCount = releaseRows.filter(r => r.release_ready).length;
const artistRows = await db.select().from(artists).orderBy(artists.name);
---

<AppLayout>
  <div class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Dashboard</h1>
      <p class="text-neutral-500 mt-1">Overview of your label operations.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <div class="bg-white border border-neutral-200 rounded-xl p-4 md:p-5">
        <p class="text-sm text-neutral-500">Artists</p>
        <p class="text-2xl md:text-3xl font-bold mt-1">{artistCount[0]?.value ?? 0}</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 md:p-5">
        <p class="text-sm text-neutral-500">Releases</p>
        <p class="text-2xl md:text-3xl font-bold mt-1">{releaseRows.length}</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 md:p-5">
        <p class="text-sm text-neutral-500">Open Bugs</p>
        <p class="text-2xl md:text-3xl font-bold mt-1">{bugCount[0]?.value ?? 0}</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 md:p-5">
        <p class="text-sm text-neutral-500">Ready</p>
        <p class="text-2xl md:text-3xl font-bold mt-1">{readyCount}/{releaseRows.length}</p>
      </div>
    </div>

    <ReleasePipeline client:load releases={releaseRows} />

    <section>
      <h2 class="text-lg font-semibold mb-3">Artists</h2>
      <div class="bg-white border border-neutral-200 rounded-xl divide-y divide-neutral-100">
        {artistRows.slice(0, 5).map((a) => (
          <a href={`/artists/${a.id}`} class="flex items-center justify-between p-4 hover:bg-neutral-50 transition-colors">
            <div>
              <p class="font-medium">{a.name}</p>
              {a.bio && <p class="text-sm text-neutral-500 line-clamp-1">{a.bio}</p>}
            </div>
            <div class="flex gap-2 text-xs">
              {a.pro && <span class="px-2 py-1 bg-neutral-100 rounded">{a.pro}</span>}
              {a.spotify_followers ? <span class="px-2 py-1 bg-green-50 text-green-700 rounded">{a.spotify_followers.toLocaleString()} followers</span> : null}
            </div>
          </a>
        ))}
      </div>
      {artistRows.length > 5 && (
        <a href="/artists" class="mt-2 inline-block text-xs text-neutral-500 hover:text-neutral-900">
          View all {artistRows.length} artists →
        </a>
      )}
    </section>
  </div>
</AppLayout>
