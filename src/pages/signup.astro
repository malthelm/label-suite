---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Label Suite — Sign Up</title>
  </head>
  <body class="min-h-screen bg-neutral-50 flex items-center justify-center antialiased">
    <div class="w-full max-w-sm">
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-8 space-y-6">
        <div class="text-center space-y-1">
          <h1 class="text-2xl font-bold tracking-tight">Create Account</h1>
          <p class="text-sm text-neutral-500">Get started with Label Suite</p>
        </div>
        <form id="signup-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Name</label>
            <input id="name" type="text" name="name" required
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
            <input id="email" type="email" name="email" required
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-neutral-700 mb-1">Password</label>
            <input id="password" type="password" name="password" required minlength="8"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <button type="submit"
            class="w-full py-2.5 bg-neutral-900 text-white text-sm font-medium rounded-lg hover:bg-neutral-800 transition-colors">
            Create Account
          </button>
        </form>
        <p class="text-center text-xs text-neutral-400">
          Already have an account? <a href="/login" class="text-neutral-700 underline">Sign in</a>
        </p>
      </div>
    </div>
    <script>
      import { signUp } from "../lib/auth-client";
      document.getElementById("signup-form")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target as HTMLFormElement);
        await signUp.email({
          name: fd.get("name") as string,
          email: fd.get("email") as string,
          password: fd.get("password") as string,
        });
        window.location.href = "/dashboard";
      });
    </script>
  </body>
</html>
