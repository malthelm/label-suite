---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { media_assets, artists, releases } from "../../db/schema";
import { desc, eq } from "drizzle-orm";

const assetRows = await db.select({
  id: media_assets.id, asset_name: media_assets.asset_name, asset_type: media_assets.asset_type,
  approval_status: media_assets.approval_status, delivery_status: media_assets.delivery_status,
  file_link: media_assets.file_link, notes: media_assets.notes, date_uploaded: media_assets.date_uploaded,
  artist_name: artists.name, release_title: releases.title,
}).from(media_assets).leftJoin(artists, eq(media_assets.linked_artist_id, artists.id))
  .leftJoin(releases, eq(media_assets.linked_release_id, releases.id))
  .orderBy(desc(media_assets.created_at)).limit(50);
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Media Assets</h1>
      <p class="text-muted-foreground mt-1">Creative assets with approval + delivery tracking.</p>
    </div>

    {!assetRows.length ? (
      <div class="p-12 text-center text-muted-foreground border-2 border-dashed border-border rounded-xl">
        <p class="text-lg">No media assets yet.</p>
      </div>
    ) : (
      <div class="bg-card border border-border rounded-xl divide-y divide-border">
        {assetRows.map((a) => (
          <div class="flex items-center justify-between p-4">
            <div>
              <p class="font-medium">{a.asset_name}</p>
              <p class="text-sm text-muted-foreground">
                {a.asset_type || "—"} · {a.artist_name || "—"} · {a.release_title || "—"}
              </p>
              {a.file_link && <a href={a.file_link} class="text-xs text-blue-600 hover:underline" target="_blank" rel="noopener">Open file →</a>}
            </div>
            <div class="flex gap-2">
              <span class={`text-xs px-2 py-1 rounded ${a.approval_status === "approved" ? "bg-green-100 text-green-700" : a.approval_status === "rejected" ? "bg-red-100 text-red-700" : "bg-muted text-muted-foreground"}`}>{a.approval_status}</span>
              <span class={`text-xs px-2 py-1 rounded ${a.delivery_status === "received" ? "bg-green-100 text-green-700" : a.delivery_status === "sent" ? "bg-blue-100 text-blue-700" : "bg-muted text-muted-foreground"}`}>{a.delivery_status}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>