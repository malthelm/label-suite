---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { media_assets, artists, releases } from "../../db/schema";
import { desc, eq, asc } from "drizzle-orm";
import { MediaAssetManager } from "../../components/media-assets/MediaAssetManager";
import type { MediaAsset } from "../../components/media-assets/MediaAssetForm";

const assetRows = await db.select({
  id: media_assets.id, asset_name: media_assets.asset_name, asset_type: media_assets.asset_type,
  linked_artist_id: media_assets.linked_artist_id, linked_release_id: media_assets.linked_release_id,
  version: media_assets.version, approval_status: media_assets.approval_status,
  delivery_status: media_assets.delivery_status, file_link: media_assets.file_link,
  notes: media_assets.notes, date_uploaded: media_assets.date_uploaded,
  artist_name: artists.name, release_title: releases.title,
}).from(media_assets).leftJoin(artists, eq(media_assets.linked_artist_id, artists.id))
  .leftJoin(releases, eq(media_assets.linked_release_id, releases.id))
  .orderBy(desc(media_assets.created_at)).limit(50);

const artistRows = await db.select({ id: artists.id, name: artists.name }).from(artists).orderBy(asc(artists.name));
const releaseRows = await db.select({ id: releases.id, title: releases.title }).from(releases).orderBy(asc(releases.title));
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Media Assets</h1>
      <p class="text-muted-foreground mt-1">Creative assets with approval + delivery tracking.</p>
    </div>
    <MediaAssetManager client:load
      initialAssets={assetRows as Array<MediaAsset & { artist_name?: string | null; release_title?: string | null }>}
      artists={artistRows}
      releases={releaseRows}
    />
  </div>
</AppLayout>