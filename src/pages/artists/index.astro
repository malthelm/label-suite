---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { artists } from "../../db/schema";
import { asc } from "drizzle-orm";
import { ArtistCreateDialog } from "../../components/artists/ArtistCreateDialog";
import { ArtistEditButton, ArtistDeleteButton } from "../../components/artists/ArtistActionButtons";

const artistRows = await db.select().from(artists).orderBy(asc(artists.name));
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Artists</h1>
      <ArtistCreateDialog client:load />
    </div>

    {!artistRows.length ? (
      <div class="p-12 text-center text-muted-foreground border-2 border-dashed border-border rounded-xl">
        <p class="text-lg">No artists yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {artistRows.map((a) => (
          <div class="block p-5 rounded-xl border border-border hover:border-border/80 hover:shadow-sm transition-all">
            <a href={`/artists/${a.id}`} class="block">
              <h2 class="text-lg font-semibold">{a.name}</h2>
              <div class="mt-2 flex flex-wrap gap-2 text-xs">
                {a.pro && <span class="px-2 py-1 bg-muted rounded-md">{a.pro}</span>}
                {a.spotify_followers ? <span class="px-2 py-1 bg-green-50 text-green-700 rounded-md">{a.spotify_followers.toLocaleString()} followers</span> : null}
              </div>
              {a.bio && <p class="mt-3 text-sm text-muted-foreground line-clamp-2">{a.bio}</p>}
            </a>
            <div class="mt-3 pt-3 border-t border-border flex gap-2">
              <ArtistEditButton client:load artist={a} />
              <ArtistDeleteButton client:load artist={a} />
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>