---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { artists } from "../../db/schema";
import { asc } from "drizzle-orm";
import { ArtistCreateDialog } from "../../components/artists/ArtistCreateDialog";

const artistRows = await db.select().from(artists).orderBy(asc(artists.name));
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Artists</h1>
      <ArtistCreateDialog client:load />
    </div>

    {!artistRows.length ? (
      <div class="p-12 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-xl">
        <p class="text-lg">No artists yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {artistRows.map((a) => (
          <a href={`/artists/${a.id}`} class="block p-5 rounded-xl border border-neutral-200 hover:border-neutral-400 hover:shadow-sm transition-all">
            <h2 class="text-lg font-semibold">{a.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2 text-xs">
              {a.pro && <span class="px-2 py-1 bg-neutral-100 rounded-md">{a.pro}</span>}
              {a.spotify_followers ? <span class="px-2 py-1 bg-green-50 text-green-700 rounded-md">{a.spotify_followers.toLocaleString()} followers</span> : null}
            </div>
            {a.bio && <p class="mt-3 text-sm text-neutral-500 line-clamp-2">{a.bio}</p>}
          </a>
        ))}
      </div>
    )}
  </div>
</AppLayout>
