---
import AppLayout from "../layouts/AppLayout.astro";
import { db } from "../lib/db";
import { budget_line_items, releases } from "../db/schema";
import { eq, desc } from "drizzle-orm";

const itemRows = await db.select({
  id: budget_line_items.id, name: budget_line_items.name, amount: budget_line_items.amount,
  status: budget_line_items.status, release_title: releases.title,
}).from(budget_line_items).leftJoin(releases, eq(budget_line_items.release_id, releases.id)).orderBy(desc(budget_line_items.created_at)).limit(50);

const total = itemRows.reduce((sum, i) => sum + (i.amount ?? 0), 0);
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Budget</h1>
      <p class="text-2xl font-bold">${total.toLocaleString()}</p>
    </div>

    {!itemRows.length ? (
      <div class="p-12 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-xl">
        <p class="text-lg">No budget items yet.</p>
      </div>
    ) : (
      <div class="bg-white border border-neutral-200 rounded-xl divide-y divide-neutral-100">
        {itemRows.map((i) => (
          <div class="flex items-center justify-between p-4">
            <div>
              <p class="font-medium">{i.name}</p>
              <p class="text-sm text-neutral-500">{i.release_title || "—"}</p>
            </div>
            <div class="text-right">
              <p class="font-medium">${i.amount?.toLocaleString()}</p>
              <span class="text-xs px-2 py-0.5 rounded bg-neutral-100 text-neutral-600">{i.status}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>
