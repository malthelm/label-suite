---
import AppLayout from "../layouts/AppLayout.astro";
import { supabase } from "../lib/supabase";

const { data: items } = await supabase.from("budget_line_items").select("id, name, amount, status, release_id, releases(title)").order("created_at", { ascending: false }).limit(50);
const total = items?.reduce((sum, i) => sum + (i.amount ?? 0), 0) ?? 0;
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Budget</h1>
      <p class="text-2xl font-bold">${total.toLocaleString()}</p>
    </div>

    {!items?.length ? (
      <div class="p-12 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-xl">
        <p class="text-lg">No budget items yet.</p>
      </div>
    ) : (
      <div class="bg-white border border-neutral-200 rounded-xl divide-y divide-neutral-100">
        {items.map((i) => (
          <div class="flex items-center justify-between p-4">
            <div>
              <p class="font-medium">{i.name}</p>
              <p class="text-sm text-neutral-500">{i.releases?.title || "—"}</p>
            </div>
            <div class="text-right">
              <p class="font-medium">${i.amount?.toLocaleString()}</p>
              <span class="text-xs px-2 py-0.5 rounded bg-neutral-100 text-neutral-600">{i.status}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>
