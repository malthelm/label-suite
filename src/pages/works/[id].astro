---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { works, roles, tracks, contacts } from "../../db/schema";
import { eq, asc } from "drizzle-orm";
import { RoleManager } from "../../components/roles/RoleManager";

const { id } = Astro.params;
if (!id) return Astro.redirect("/works");

const workRows = await db.select().from(works).where(eq(works.id, id));
const work = workRows[0];
const roleRows = await db.select({
  id: roles.id, contact_id: roles.contact_id, role: roles.role, scope: roles.scope,
  ownership_type: roles.ownership_type, percent_share: roles.percent_share,
  clearance_status: roles.clearance_status, contact_name: contacts.name,
}).from(roles).leftJoin(contacts, eq(roles.contact_id, contacts.id)).where(eq(roles.work_id, id));
const contactRows = await db.select({ id: contacts.id, name: contacts.name }).from(contacts).orderBy(asc(contacts.name));
const trackRows = await db.select().from(tracks).where(eq(tracks.work_id, id)).orderBy(asc(tracks.position));
---

<AppLayout>
  {!work ? <p class="text-muted-foreground">Work not found.</p> : (
    <div class="space-y-8">
      <div>
        <h1 class="text-3xl font-bold tracking-tight">{work.title}</h1>
        <p class="text-muted-foreground mt-1">{work.isrc || "No ISRC"} · {work.genre || "No genre"}</p>
      </div>

      <RoleManager client:load workId={work.id} contacts={contactRows} roles={roleRows} />

      <section>
        <h2 class="text-lg font-semibold mb-3">Tracks using this work — {trackRows.length}</h2>
        <div class="bg-card border border-border rounded-xl divide-y divide-border">
          {trackRows.map((t) => {
            const pubPct = Math.round((t.clearance_pub ?? 0) * 100);
            const masterPct = Math.round((t.clearance_master ?? 0) * 100);
            const overallPct = Math.round((t.clearance_progress ?? 0) * 100);
            const ready = t.track_ready;
            return (
              <a href={`/releases/${t.release_id}`} class="block p-4 hover:bg-accent transition-colors">
                <div class="flex items-center justify-between mb-2">
                  <div>
                    <p class="font-medium">{t.title}</p>
                    <p class="text-sm text-muted-foreground">{t.isrc || "No ISRC"}</p>
                  </div>
                  <span class={`text-xs px-2 py-1 rounded-md shrink-0 ${ready ? "bg-green-100 text-green-700" : "bg-muted text-muted-foreground"}`}>
                    {ready ? "Ready" : `${overallPct}%`}
                  </span>
                </div>
                {!ready && (
                  <div class="space-y-1.5">
                    <div>
                      <div class="flex items-center justify-between text-xs text-muted-foreground mb-0.5">
                        <span>Publishing</span>
                        <span>{pubPct}%</span>
                      </div>
                      <div class="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                        <div
                          class="h-full bg-blue-500 rounded-full transition-all"
                          style={`width: ${Math.min(pubPct, 100)}%`}
                        />
                      </div>
                    </div>
                    <div>
                      <div class="flex items-center justify-between text-xs text-muted-foreground mb-0.5">
                        <span>Master</span>
                        <span>{masterPct}%</span>
                      </div>
                      <div class="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                        <div
                          class="h-full bg-amber-500 rounded-full transition-all"
                          style={`width: ${Math.min(masterPct, 100)}%`}
                        />
                      </div>
                    </div>
                  </div>
                )}
              </a>
            );
          })}
          {!trackRows.length && <p class="p-4 text-sm text-muted-foreground">No tracks linked.</p>}
        </div>
      </section>
    </div>
  )}
</AppLayout>