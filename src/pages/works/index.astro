---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { works } from "../../db/schema";
import { asc } from "drizzle-orm";

const workRows = await db.select().from(works).orderBy(asc(works.title));
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Works</h1>
      <a href="/works/new" class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium rounded-lg hover:bg-primary/80 transition-colors">+ New Work</a>
    </div>

    {!workRows.length ? (
      <div class="p-12 text-center text-muted-foreground border-2 border-dashed border-border rounded-xl">
        <p class="text-lg">No works yet.</p>
      </div>
    ) : (
      <div class="bg-card border border-border rounded-xl divide-y divide-border">
        {workRows.map((w) => (
          <a href={`/works/${w.id}`} class="flex items-center justify-between p-4 hover:bg-accent transition-colors">
            <div>
              <p class="font-medium">{w.title}</p>
              <p class="text-sm text-muted-foreground">{w.isrc || "No ISRC"} · {w.genre || "No genre"}</p>
            </div>
            {w.audio_url ? <span class="text-xs text-green-600">Audio ✓</span> : null}
          </a>
        ))}
      </div>
    )}
  </div>
</AppLayout>