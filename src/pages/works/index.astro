---
import AppLayout from "../../layouts/AppLayout.astro";
import { db } from "../../lib/db";
import { works } from "../../db/schema";
import { asc } from "drizzle-orm";

const workRows = await db.select().from(works).orderBy(asc(works.title));
---

<AppLayout>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Works</h1>
      <a href="/works/new" class="inline-flex items-center px-4 py-2 bg-neutral-900 text-white text-sm font-medium rounded-lg hover:bg-neutral-800 transition-colors">+ New Work</a>
    </div>

    {!workRows.length ? (
      <div class="p-12 text-center text-neutral-400 border-2 border-dashed border-neutral-200 rounded-xl">
        <p class="text-lg">No works yet.</p>
      </div>
    ) : (
      <div class="bg-white border border-neutral-200 rounded-xl divide-y divide-neutral-100">
        {workRows.map((w) => (
          <a href={`/works/${w.id}`} class="flex items-center justify-between p-4 hover:bg-neutral-50 transition-colors">
            <div>
              <p class="font-medium">{w.title}</p>
              <p class="text-sm text-neutral-500">{w.isrc || "No ISRC"} · {w.genre || "No genre"}</p>
            </div>
            {w.audio_url ? <span class="text-xs text-green-600">Audio ✓</span> : null}
          </a>
        ))}
      </div>
    )}
  </div>
</AppLayout>
