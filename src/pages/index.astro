---
import Layout from "../layouts/Layout.astro";
---

<section class="space-y-8">
  <div class="space-y-3">
    <h1 class="text-4xl font-bold tracking-tight">Label Suite</h1>
    <p class="text-lg text-neutral-500 max-w-2xl">
      Independent music label operations — releases, clearance tracking, ISRC generation, and your daily cockpit.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
    <a href="/releases" class="block p-6 rounded-xl border border-neutral-200 hover:border-neutral-400 transition-colors">
      <h2 class="text-lg font-semibold mb-2">📀 Releases</h2>
      <p class="text-sm text-neutral-500">Track releases from draft to distribution with computed readiness.</p>
    </a>
    <a href="/artists" class="block p-6 rounded-xl border border-neutral-200 hover:border-neutral-400 transition-colors">
      <h2 class="text-lg font-semibold mb-2">🎤 Artists</h2>
      <p class="text-sm text-neutral-500">Roster management with Spotify integration and PRO data.</p>
    </a>
    <a href="/today" class="block p-6 rounded-xl border border-neutral-200 hover:border-neutral-400 transition-colors">
      <h2 class="text-lg font-semibold mb-2">📋 Today Hub</h2>
      <p class="text-sm text-neutral-500">Daily cockpit: calls, deadlines, and blockers at a glance.</p>
    </a>
  </div>
</section>
